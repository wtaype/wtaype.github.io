import Layout from '../layouts/Layout.astro';
import { Saludar, year, wiTip } from '../lib/widev.js';
import { seo } from '../lib/seo.js';

// ── Datos Estáticos ──────────────────────────────────────────────────────────
const ROLES = ['Desarrollador Full Stack', 'Ingeniero de Sistemas', 'Creador de Soluciones'];
const STATS = [
  [6, 'Años de Experiencia'],
  [60, 'Proyectos Entregados'],
  [30, 'Tecnologías Dominadas']
];

// 4 Tecnologías flotantes del Hero
const TECHS = [
  ['Astro', 'fas fa-rocket', '#FF5D01'],
  ['JavaScript', 'fab fa-js', '#F7DF1E'],
  ['Node.js', 'fab fa-node-js', '#68A063'],
  ['Firebase', 'fas fa-fire', '#FFA611']
];

const FORTALEZAS = [
  'Desarrollo Full Stack',
  'Optimización de Rendimiento',
  'UI/UX Intuitivo y Dinámico',
  'Soluciones de Software Escalables',
  'Multiplataforma (Web / Android / Windows)',
  'Arquitecturas Cloud & APIs Robundas'
];

const TRAYECTORIA = [
  [year(), 'Creando proyectos innovadores con tecnologías web de vanguardia'],
  ['2025', 'Graduado de Ingeniería de Sistemas · +40 proyectos completados con éxito'],
  ['2021', 'Universidad San Ignacio de Loyola — Ingeniería Empresarial'],
  ['2017', 'Inicio de mi camino profesional en el mundo del desarrollo de software']
];

const STACK = [
  ['Astro', 'fas fa-rocket', '#FF5D01'],
  ['JavaScript', 'fab fa-js-square', '#F7DF1E'],
  ['Node.js', 'fab fa-node-js', '#68A063'],
  ['Firebase', 'fas fa-fire', '#FFA611'],
  ['Supabase', 'fas fa-database', '#3ECF8E'],
  ['React', 'fab fa-react', '#61DAFB'],
  ['Next.js', 'fas fa-bolt', '#000000'],
  ['Vite', 'fas fa-bolt', '#646CFF'],
  ['Kotlin', 'fab fa-kotlin', '#7F52FF'],
  ['Jetpack Compose', 'fab fa-android', '#4285F4'],
  ['Tauri', 'fas fa-laptop-code', '#FFC131'],
  ['Rust', 'fab fa-rust', '#E05D44'],
  ['WebRTC', 'fas fa-network-wired', '#326CE5'],
  ['Vercel', 'fas fa-bolt', '#000000'],
  ['Wordpress', 'fab fa-wordpress', '#21759b'],
  ['HTML5', 'fab fa-html5', '#E34F26'],
  ['CSS3', 'fab fa-css3-alt', '#1572B6'],
  ['Git', 'fab fa-git-alt', '#F05032'],
  ['GitHub', 'fab fa-github', '#6e40c9']
];

const SERVICIOS = [
  { icon: 'fas fa-globe', titulo: 'Aplicaciones Web', desc: 'SPAs modernas con React, Next.js y Astro. Rápidas, seguras y optimizadas para Lighthouse.' },
  { icon: 'fas fa-mobile-alt', titulo: 'Desarrollo Android', desc: 'Interfaces móviles fluidas, adaptables y construidas bajo metodologías de alto rendimiento.' },
  { icon: 'fas fa-desktop', titulo: 'Soluciones Windows', desc: 'Software de escritorio robusto y veloz diseñado para la automatización y control de procesos.' },
  { icon: 'fas fa-bolt', titulo: 'Rendimiento & SEO', desc: 'Auditorías de carga, optimización avanzada de assets y estructuración para motores de búsqueda.' },
  { icon: 'fas fa-database', titulo: 'Cloud & APIs', desc: 'Estructuración de servidores escalables, bases de datos no relacionales y APIs robustas.' },
  { icon: 'fas fa-graduation-cap', titulo: 'Sistemas Escalables', desc: 'Arquitecturas de código limpio pensadas a futuro, fáciles de documentar, mantener y expandir.' },
  { icon: 'fas fa-robot', titulo: 'IA & Automatización', desc: 'Integración de modelos LLM, agentes autónomos y automatización de procesos inteligentes.' },
  { icon: 'fas fa-shield-alt', titulo: 'Seguridad & Cloud', desc: 'Configuración segura de infraestructura en la nube, bases de datos protegidas y auditorías de código.' }
];

// Fallback estático de Proyectos Destacados (Favoritos) por seguridad
let proyectosDestacados = [
  { id: 'lovewi', titulo: 'Lovewi — Mensajes de Amor', img: 'https://lovewi.web.app/poster.webp', descripcion: 'Crea mensajes de amor únicos y personalizados para San Valentín y fechas especiales.', url: 'https://lovewi.web.app/', tecnologias: ['Canvas','JavaScript','CSS3'] },
  { id: 'loveeye', titulo: 'Love Eye — Cuida tus Ojitos', img: 'https://loveye.web.app/poster.webp', descripcion: 'Guía completa para el cuidado de la visión. Prevención, diagnóstico y ejercicios.', url: 'https://loveye.web.app/', tecnologias: ['jQuery','JS','CSS3'] },
  { id: 'wiihope', titulo: 'WiiHope — Confía en Dios', img: 'https://wiihope.web.app/poster.webp', descripcion: 'Plataforma cristiana para orar, leer frases bíblicas y escuchar la Biblia en audio.', url: 'https://wiihope.web.app/', tecnologias: ['Web','jQuery','HTML'] }
];

// Lógica de datos de Firestore REST
const firebaseProjectId = import.meta.env.PUBLIC_FIREBASE_PROJECT_ID || 'wtaype';
let posts: any[] = [];

// Helper para convertir el formato JSON complejo de Firestore REST a un objeto limpio de JS
function parseFirestore(doc: any) {
  const fields = doc.fields || {};
  const res: any = {};
  for (const [k, v] of Object.entries(fields)) {
    const val: any = v;
    res[k] = val.stringValue ?? val.timestampValue ?? val.booleanValue ?? val.integerValue ?? val.doubleValue ?? val.arrayValue?.values?.map((x: any) => x.stringValue) ?? null;
  }
  res.id = doc.name.split('/').pop();
  return res;
}

try {
  // 1. Obtener Proyectos Destacados desde Firestore
  const proyectosRes = await fetch(`https://firestore.googleapis.com/v1/projects/${firebaseProjectId}/databases/(default)/documents/proyectos`);
  if (proyectosRes.ok) {
    const rawProyectos = await proyectosRes.json();
    if (rawProyectos.documents) {
      const parsedProyectos = rawProyectos.documents.map(parseFirestore);
      // Filtrar por favoritos/destacados y limitar a 4
      const filtrados = parsedProyectos.filter((p: any) => p.destacado === true);
      if (filtrados.length > 0) {
        proyectosDestacados = filtrados.slice(0, 4);
      }
    }
  }
} catch (e) {
  console.warn('Usando fallback estático para proyectos destacados en compilación:', e);
}

try {
  // 2. Obtener Artículos de Blog desde Firestore (Límite 12)
  const blogRes = await fetch(`https://firestore.googleapis.com/v1/projects/${firebaseProjectId}/databases/(default)/documents/blog`);
  if (blogRes.ok) {
    const rawBlog = await blogRes.json();
    if (rawBlog.documents) {
      const parsedBlog = rawBlog.documents.map(parseFirestore);
      // Filtrar los que estén activos y ordenar por fecha (creadoEn)
      posts = parsedBlog
        .filter((p: any) => p.activo !== false)
        .sort((a: any, b: any) => new Date(b.creado || b.creadoEn || 0).getTime() - new Date(a.creado || a.creadoEn || 0).getTime())
        .slice(0, 4);
    }
  }
} catch (e) {
  console.warn('No se pudieron obtener posts de blog desde Firestore en compilación:', e);
}
