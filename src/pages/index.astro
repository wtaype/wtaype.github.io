<style is:global>
.inicio { max-width: 1400px; margin: 0 auto; padding: 0 2vw; }

/* ══════════════════ HERO SECTION ══════════════════ */
.hero {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 6vw;
  align-items: center;
  min-height: 85vh;
  padding: 6vh 0;
}
.hero_txt {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}
.hero_saludo {
  display: inline-flex;
  align-items: center;
  gap: 1vh;
  font-size: var(--fz_m4);
  font-weight: 600;
  color: var(--tx);
  margin-bottom: 2.5vh;
  padding: 0.8vh 2vh;
  background: color-mix(in srgb, var(--mco) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--mco) 15%, transparent);
  border-radius: 50px;
  animation: slideInLeft 0.8s ease;
}
.saludo_emoji {
  font-size: var(--fz_l1);
  animation: wave 1.5s infinite;
  transform-origin: 70% 70%;
}
.hero_title {
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 900;
  color: var(--tx);
  line-height: 1.1;
  margin-bottom: 0.5vh;
  animation: slideInLeft 0.8s ease 0.2s backwards;
  letter-spacing: -2px;
}
.gradient_text {
  background: linear-gradient(135deg, var(--mco) 0%, var(--bg2) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero_sub_tit {
  font-size: var(--fz_l1);
  font-weight: 800;
  display: block;
  margin-bottom: 2.5vh;
  animation: slideInLeft 0.8s ease 0.3s backwards;
}
.hero_roles {
  height: 4vh;
  margin-bottom: 3vh;
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: flex-start;
  width: 100%;
  animation: slideInLeft 0.8s ease 0.4s backwards;
}
.role {
  position: absolute;
  font-size: var(--fz_l1);
  font-weight: 700;
  color: var(--mco);
  opacity: 0;
  transform: translateY(100%);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
.role.active {
  opacity: 1;
  transform: translateY(0);
}
.hero_subtitle {
  font-size: var(--fz_m3);
  color: var(--tx3);
  line-height: 1.6;
  margin-bottom: 4vh;
  max-width: 600px;
  animation: slideInLeft 0.8s ease 0.6s backwards;
}
.hero_stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2vw;
  margin-bottom: 4vh;
  width: 100%;
  animation: slideInLeft 0.8s ease 0.8s backwards;
}
.stat_card {
  text-align: center;
  padding: 2.5vh 1.2vw;
  background: var(--bg1);
  border-radius: 12px;
  border: 1px solid transparent;
  transition: all var(--tr_m);
}
.stat_card:hover {
  border-color: var(--mco);
  transform: translateY(-5px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}
.stat_number {
  font-size: var(--fz_x1);
  font-weight: 850;
  color: var(--mco);
  line-height: 1;
  margin-bottom: 0.5vh;
}
.stat_label {
  font-size: var(--fz_s4);
  color: var(--txe);
  font-weight: 600;
}
.hero_actions {
  display: flex;
  gap: 2vh;
  animation: slideInLeft 0.8s ease 1s backwards;
  flex-wrap: wrap;
}
.btn_primary,
.btn_secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 1.2vh;
  padding: 1.5vh 3.5vh;
  border-radius: 12px;
  font-size: var(--fz_m2);
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  text-decoration: none;
  border: 2px solid transparent;
  white-space: nowrap;
}
.btn_principal {
  background: linear-gradient(135deg, var(--mco), var(--bg2)) !important;
  color: var(--txa) !important;
  border: none !important;
  box-shadow: 0 4px 15px color-mix(in srgb, var(--mco) 30%, transparent);
}
.btn_principal:hover {
  transform: translateY(-3px) scale(1.02);
  box-shadow: 0 8px 24px color-mix(in srgb, var(--mco) 45%, transparent);
}
.btn_secundario {
  background: var(--bg1) !important;
  color: var(--tx) !important;
  border: 1px solid var(--bg5) !important;
  backdrop-filter: blur(8px);
}
.btn_secundario:hover {
  border-color: var(--mco) !important;
  background: var(--bg4) !important;
  transform: translateY(-3px);
}

/* ══════════════════ HERO VISUAL (DISEÑO ANILLOS) ══════════════════ */
.hero_visual {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 55vh;
  animation: fadeIn 1s ease 0.5s backwards;
  width: 100%;
  max-width: 480px;
  margin: 0 auto;
}
.profile_container {
  position: relative;
  width: 320px;
  height: 320px;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
}
.profile_ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3px solid var(--mco);
  border-top-color: transparent;
  animation: rotate 10s linear infinite;
  pointer-events: none;
}
.ring2 {
  width: 112%;
  height: 112%;
  border-color: var(--bg2);
  border-bottom-color: transparent;
  animation-direction: reverse;
  animation-duration: 8s;
}
.profile_img_wrapper {
  width: 85%;
  height: 85%;
  border-radius: 50%;
  border: 5px solid var(--wb);
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.profile_img_wrapper:hover {
  transform: scale(1.05);
}
.profile_img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.profile_badge {
  position: absolute;
  bottom: 8%;
  right: 8%;
  background: var(--success);
  color: #fff;
  padding: 0.8vh 1.8vh;
  border-radius: 50px;
  font-size: var(--fz_s4);
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 0.5vh;
  box-shadow: 0 4px 16px rgba(60, 215, 65, 0.3);
  animation: pulse 2s infinite;
  z-index: 3;
}
.profile_badge i {
  animation: blink 1.5s infinite;
}
.floating_tech {
  position: absolute;
  width: 65px;
  height: 65px;
  background: var(--wb);
  border: 1px solid var(--brd);
  border-radius: 16px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 1.8rem;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  animation: float 4s ease-in-out infinite;
  cursor: pointer;
  transition: all var(--tr_m);
  z-index: 4;
}
.floating_tech:hover {
  transform: translateY(-10px) scale(1.1);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
  border-color: var(--pill-color);
}
.floating_tech i {
  color: var(--pill-color);
}
.tech1 { top: 8%; left: -6%; animation-delay: 0s; --pill-color: #FF5D01; }
.tech2 { top: 22%; right: -8%; animation-delay: 0.8s; --pill-color: #F7DF1E; }
.tech3 { bottom: 25%; left: -8%; animation-delay: 1.6s; --pill-color: #68A063; }
.tech4 { bottom: 12%; right: -6%; animation-delay: 2.4s; --pill-color: #FFA611; }

@keyframes rotate { to { transform: rotate(360deg); } }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-18px); } }
@keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
@keyframes wave {
  0%, 100% { transform: rotate(0deg); }
  10%, 30% { transform: rotate(14deg); }
  20% { transform: rotate(-8deg); }
  40% { transform: rotate(-4deg); }
  50% { transform: rotate(10deg); }
}
@keyframes slideInLeft { from { opacity: 0; transform: translateX(-30px); } to { opacity: 1; transform: translateX(0); } }

/* ══════════════════ SECCIONES BASE ══════════════════ */
.inicio section { padding: 9vh 0; }
.sec_header {
  text-align: center;
  margin-bottom: 6vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.sec_title {
  font-size: var(--fz_x1);
  font-weight: 800;
  color: var(--tx);
