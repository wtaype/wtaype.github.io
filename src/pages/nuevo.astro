<script>
  import { db } from '../lib/firebase.js';
  import { doc, getDoc, setDoc, updateDoc, serverTimestamp } from 'firebase/firestore';
  import { protegerRuta } from '../lib/auth.js';
  import { wiSpin, Notificacion, Mensaje, getls, savels } from '../lib/widev.js';
  import { linkweb } from '../wii.js';

  let tags: string[] = [];
  let sT: any, iT: any, iT2: any;
  let isEdit = false;
  let editSlug: string | null = null;
  let draftTimer: any = null;
  let eventListeners: { target: EventTarget; type: string; handler: EventListener }[] = [];

  const COL = 'blog';

  const toSlug = (s: string) => s.trim().toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'')
    .replace(/\b(el|la|los|las|de|del|en|un|una|y|a|con|por|para|que|es|se)\b/g,' ')
    .replace(/[^a-z0-9\s_-]/g,'').replace(/\s+/g,'-').replace(/[-_]{2,}/g,'-').replace(/^[-_]|[-_]$/g,'').slice(0,50);

  const countWords = (html: string) => {
    const t = html.replace(/<[^>]*>/g,' ').split(/\s+/).filter(Boolean);
    return { words: t.length, min: Math.max(1, Math.ceil(t.length/200)) };
  };

  const getEditSlug = () => new URLSearchParams(window.location.search).get('edit') || null;

  const listen = (target: EventTarget, type: string, handler: EventListener) => {
    target.addEventListener(type, handler);
    eventListeners.push({ target, type, handler });
  };

  const cleanup = () => {
    clearTimeout(draftTimer);
    clearTimeout(iT);
    clearTimeout(iT2);
    eventListeners.forEach(({ target, type, handler }) => {
      target.removeEventListener(type, handler);
    });
    eventListeners = [];
    tags = [];
    isEdit = false;
    editSlug = null;
  };

  const toMs = (v: any) => {
    if (!v) return null;
    if (v.seconds) return v.seconds * 1000;
    const dateObj = new Date(v);
    return isNaN(dateObj.getTime()) ? null : dateObj.getTime();
  };

  const ser = (d: any) => {
    if (!d) return null;
    return {
      ...d,
      resumen: d.descripcion || '',
      keywords: d.metaSEO?.keywords || '',
      contenidoMd: d.contenidoMD || '',
      tiempoLectura: d.lecturaTM || '',
      creado: toMs(d.creado),
      actualizado: toMs(d.actualizado)
    };
  };

  const getPost = async (slug: string, force = false) => {
    if (!force) { const c = getls(`wi_post_${slug}`); if (c) return { data: c, fromCache: true }; }
    const docSnap = await getDoc(doc(db, 'blog', slug));
    if (!docSnap.exists()) return null;
    const mapped = ser({ id: docSnap.id, ...docSnap.data() });
    savels(`wi_post_${slug}`, mapped, 12);
    return { data: mapped, fromCache: false };
  };

  const clearPostCache = (s: string) => { if (typeof localStorage !== 'undefined') localStorage.removeItem(`wi_post_${s}`); };
  const clearBlogCache = () => { if (typeof localStorage !== 'undefined') Object.keys(localStorage).filter(k => k.startsWith('wi_blogs')).forEach(k => localStorage.removeItem(k)); };

  const wiSanihtml = (html: string) => {
    if (!html) return '';
    let str = html.toString();
    str = str.replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '');
    str = str.replace(/<style\b[^<]*(?:(?!<\/style>)<[^<]*)*<\/style>/gi, '');
    str = str.replace(/(\bon[a-z]+\s*=\s*"[^"]*")/gi, '');
    str = str.replace(/(\bon[a-z]+\s*=\s*'[^']*')/gi, '');
    str = str.replace(/(\bon[a-z]+\s*=\s*[^\s>]+)/gi, '');
    str = str.replace(/<\/?(iframe|embed|object|applet)\b[^>]*>/gi, '');
    str = str.replace(/href\s*=\s*(['"]?)\s*javascript:[^>]*\1/gi, 'href="#"');
    return str;
  };

  const CUSTOM_ICONS: Record<string, string> = {
    'corazon': '<i class="fas fa-heart po_ico_red"></i>',
    'heart': '<i class="fas fa-heart po_ico_red"></i>',
    'estrella': '<i class="fas fa-star po_ico_yellow"></i>',
    'star': '<i class="fas fa-star po_ico_yellow"></i>',
    'si': '<i class="fas fa-circle-check po_ico_green"></i>',
    'check': '<i class="fas fa-circle-check po_ico_green"></i>',
    'no': '<i class="fas fa-circle-xmark po_ico_red"></i>',
    'times': '<i class="fas fa-circle-xmark po_ico_red"></i>',
    'maletin': '<i class="fas fa-briefcase po_ico_mco"></i>',
    'briefcase': '<i class="fas fa-briefcase po_ico_mco"></i>',
    'foco': '<i class="fas fa-lightbulb po_ico_yellow"></i>',
    'idea': '<i class="fas fa-lightbulb po_ico_yellow"></i>',
    'lightbulb': '<i class="fas fa-lightbulb po_ico_yellow"></i>',
    'grafico': '<i class="fas fa-chart-line po_ico_cyan"></i>',
    'chart': '<i class="fas fa-chart-line po_ico_cyan"></i>',
    'usuario': '<i class="fas fa-user-tie po_ico_gold"></i>',
    'user': '<i class="fas fa-user-tie po_ico_gold"></i>',
    'cruz': '<i class="fas fa-cross po_ico_mco"></i>',
    'cross': '<i class="fas fa-cross po_ico_mco"></i>',
    'biblia': '<i class="fas fa-book-bible po_ico_mco"></i>',
    'bible': '<i class="fas fa-book-bible po_ico_mco"></i>',
    'oracion': '<i class="fas fa-hands-praying po_ico_gold"></i>',
    'pray': '<i class="fas fa-hands-praying po_ico_gold"></i>',
    'paloma': '<i class="fas fa-dove po_ico_cyan"></i>',
    'dove': '<i class="fas fa-dove po_ico_cyan"></i>',
    'alerta': '<i class="fas fa-triangle-exclamation po_ico_warning"></i>',
    'warning': '<i class="fas fa-triangle-exclamation po_ico_warning"></i>',
    'info': '<i class="fas fa-circle-info po_ico_cyan"></i>'
  };

  const mdToHtml = (md: string) => {
    if (!md) return '';
    let html = md
      .replace(/^## (.*?)(?:\s*\{\#([a-zA-Z0-9_-]+)\})?\s*$/gim, (match, title, id) => {
        return id ? `<h2 id="${id}">${title.trim()}</h2>` : `<h2>${title.trim()}</h2>`;
      })
      .replace(/^### (.*?)(?:\s*\{\#([a-zA-Z0-9_-]+)\})?\s*$/gim, (match, title, id) => {
        return id ? `<h3 id="${id}">${title.trim()}</h3>` : `<h3>${title.trim()}</h3>`;
      })
      .replace(/^\> (.*$)/gim, '<blockquote>$1</blockquote>')
      .replace(/\*\*(.*?)\*\*/gim, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/gim, '<em>$1</em>')
      .replace(/~~(.*?)~~/gim, '<del>$1</del>')
      .replace(/`([^`]+)`/gim, '<code>$1</code>')
      .replace(/!\[(.*?)\]\((.*?)\)/gim, '<figure class="po_figure"><img alt="$1" src="$2" /><figcaption class="po_figcaption">$1</figcaption></figure>')
      .replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
      .replace(/^---/gim, '<hr class="po_hr"/>');

    // Reemplazar iconos personalizados con estilos
    Object.keys(CUSTOM_ICONS).forEach(key => {
      const regex = new RegExp(`:${key}:`, 'gim');
      html = html.replace(regex, CUSTOM_ICONS[key]);
    });

    // Soporte para iconos Font Awesome genéricos
    html = html
      .replace(/:fa-([a-z0-9-]+):/gim, '<i class="fas fa-$1"></i>')
      .replace(/:far-([a-z0-9-]+):/gim, '<i class="far fa-$1"></i>')
      .replace(/:fab-([a-z0-9-]+):/gim, '<i class="fab fa-$1"></i>');

    const lines = html.split('\n');
    const result: string[] = [];
    let inList = false;
    let inTable = false;

    lines.forEach(line => {
      const trimLine = line.trim();

      // Table parsing logic
      if (trimLine.startsWith('|') && trimLine.endsWith('|')) {
        if (!inTable) {
          result.push('<div class="po_table_wrap"><table>');
          inTable = true;
        }
        if (trimLine.match(/^\|?[\s\-\|:]+\|?$/)) return;
        
        const cells = trimLine.split('|').filter((c, i, a) => (i > 0 && i < a.length - 1));
        const isHeader = inTable && result[result.length-1].includes('<table>');
        const tag = isHeader ? 'th' : 'td';
        result.push('<tr>' + cells.map(c => `<${tag}>${c.trim()}</${tag}>`).join('') + '</tr>');
        return;
      } else if (inTable) {
        result.push('</table></div>');
        inTable = false;
      }

      // List parsing logic
      const listMatch = line.match(/^[\-\*]\s+(.*)$/);
      if (listMatch) {
        if (!inList) { result.push('<ul>'); inList = true; }
        let text = listMatch[1];
        if (text.startsWith('[ ] ')) text = '<input type="checkbox" class="po_todo_check" disabled> ' + text.slice(4);
        else if (text.startsWith('[x] ')) text = '<input type="checkbox" class="po_todo_check" checked disabled> ' + text.slice(4);
        result.push(`<li>${text}</li>`);
      } else {
        if (inList) { result.push('</ul>'); inList = false; }
        if (trimLine === '') return;
        if (!line.match(/^<(h2|h3|ul|ol|li|blockquote|img|hr|div|table|tr|th|td|figure|figcaption)/)) {
          result.push(`<p>${line}</p>`);
        } else {
          result.push(line);
        }
      }
    });

    if (inTable) result.push('</table></div>');
    if (inList) result.push('</ul>');
    return result.join('\n');
  };

  const getDraftKey = () => isEdit ? 'wi_draft_edit_' + editSlug : 'wi_draft_new';

  const saveDraft = () => {
    const key = getDraftKey();
    const draft = {
      titulo: (document.getElementById('nu_titulo') as HTMLInputElement)?.value || '',
      slug: (document.getElementById('nu_slug_inp') as HTMLInputElement)?.value || '',
      resumen: (document.getElementById('nu_resumen') as HTMLTextAreaElement)?.value || '',
      keywords: (document.getElementById('nu_keywords') as HTMLTextAreaElement)?.value || '',
      cat: (document.getElementById('nu_cat_inp') as HTMLInputElement)?.value || '',
      img: (document.getElementById('nu_img') as HTMLInputElement)?.value || '',
      imgTop: (document.getElementById('nu_img_top') as HTMLInputElement)?.value || '',
      content: (document.getElementById('nu_contenido') as HTMLTextAreaElement)?.value || '',
      tags
    };
    localStorage.setItem(key, JSON.stringify(draft));
  };

  const triggerDraftSave = () => {
    clearTimeout(draftTimer);
    draftTimer = setTimeout(saveDraft, 1000);
  };

  const updCount = () => {
    const val = (document.getElementById('nu_contenido') as HTMLTextAreaElement)?.value || '';
    const { words, min } = countWords(val);
    const wordsEl = document.getElementById('nu_palabras');
    const readingEl = document.getElementById('nu_lectura');
    if (wordsEl) wordsEl.innerHTML = `<i class="fas fa-font"></i> ${words} palabras`;
    if (readingEl) readingEl.innerHTML = `<i class="fas fa-clock"></i> ${min} min`;
  };

  const renderTags = () => {
    const box = document.getElementById('nu_tags_box');
    if (box) {
      box.innerHTML = tags.map((t, i) => `
        <span class="nu_tag_chip">#${t} <i class="fas fa-xmark nu_tag_rm" data-i="${i}"></i></span>
      `).join('');
    }
  };

  const cargarSugerencias = () => {
    try {
      const setCats = new Set<string>(), setTags = new Set<string>();
      for (let i = 0; i < localStorage.length; i++) {
        const k = localStorage.key(i);
        if (k && (k.startsWith('wi_blogs') || k.startsWith('wi_post_'))) {
          const raw = localStorage.getItem(k);
          if (raw) {
            let list: any[] = [];
            try {
              const parsed = JSON.parse(raw);
              const arr = parsed.value ?? parsed;
              list = Array.isArray(arr) ? arr : (arr ? [arr] : []);
            } catch (_) {}
            list.forEach(p => {
              if (p.categoria) setCats.add(p.categoria);
              if (p.tags && Array.isArray(p.tags)) p.tags.forEach((t: any) => setTags.add(t));
            });
          }
        }
      }
      const defaultCats = ['IA', 'Programación', 'Frontend', 'Backend', 'Portafolio', 'Herramientas', 'Ciberseguridad', 'Astro'];
      const defaultTags = ['ia', 'webdev', 'javascript', 'typescript', 'react', 'nextjs', 'astro', 'python', 'portfolio', 'css', 'firebase', 'software'];
      
      const catsToRender = setCats.size > 0 ? Array.from(setCats) : defaultCats;
      const tagsToRender = setTags.size > 0 ? Array.from(setTags) : defaultTags;

    } catch (e) {
      console.warn('No se pudieron cargar sugerencias', e);
    }
  };

  const setupEvents = (u: any) => {
    const form = document.getElementById('nu_form');
    const slugInp = document.getElementById('nu_slug_inp') as HTMLInputElement;
    const titleInp = document.getElementById('nu_titulo') as HTMLInputElement;
    const resumenInp = document.getElementById('nu_resumen') as HTMLTextAreaElement;
    const keywordsInp = document.getElementById('nu_keywords') as HTMLTextAreaElement;

    const updateTituloCounter = () => {
      const cnt = document.getElementById('nu_titulo_cnt');
      const msg = document.getElementById('nu_titulo_msg');
      if (titleInp && cnt && msg) {
        const len = titleInp.value.length;
        cnt.textContent = String(len);
        if (len === 0) {
          msg.textContent = '';
          msg.className = 'nu_status_msg';
        } else if (len < 35) {
          msg.textContent = `Te faltan ${35 - len} para tener un título ideal (Mínimo: 35)`;
          msg.className = 'nu_status_msg warning';
        } else {
          msg.textContent = `Excelente título de ${len}/47`;
          msg.className = 'nu_status_msg success';
        }
      }
    };

    const updateSlugCounter = () => {
      const cnt = document.getElementById('nu_slug_cnt');
      const msg = document.getElementById('nu_slug_msg');
      if (slugInp && cnt && msg) {
        const len = slugInp.value.length;
        cnt.textContent = String(len);
        if (len === 0) {
          msg.textContent = '';
          msg.className = 'nu_status_msg';
        } else if (len < 11) {
          msg.textContent = `Te faltan ${11 - len} para tener un enlace ideal (Mínimo: 11)`;
          msg.className = 'nu_status_msg warning';
        } else if (len <= 32) {
          msg.textContent = `Excelente enlace de ${len}/32`;
          msg.className = 'nu_status_msg success';
        } else {
          msg.textContent = `Te pasaste por ${len - 32}. Máximo: 32`;
          msg.className = 'nu_status_msg error';
        }
      }
    };

    const updateResumenCounter = () => {
      const cnt = document.getElementById('nu_resumen_cnt');
      const msg = document.getElementById('nu_resumen_msg');
      if (resumenInp && cnt && msg) {
        const len = resumenInp.value.length;
        cnt.textContent = String(len);
        if (len === 0) {
          msg.textContent = '';
          msg.className = 'nu_status_msg';
        } else if (len < 100) {
          msg.textContent = `Te faltan ${100 - len} para tener una descripción ideal (Mínimo: 100)`;
          msg.className = 'nu_status_msg warning';
        } else if (len <= 150) {
          msg.textContent = `Excelente descripción de ${len}/150`;
          msg.className = 'nu_status_msg success';
        } else {
          msg.textContent = `Te pasaste por ${len - 150}. Máximo: 150`;
          msg.className = 'nu_status_msg error';
        }
      }
    };

    const updateKeywordsCounter = () => {
      const cnt = document.getElementById('nu_keywords_cnt');
      const msg = document.getElementById('nu_keywords_msg');
      if (keywordsInp && cnt && msg) {
        const val = keywordsInp.value.trim();
        const kwArr = val ? val.split(',').map(k => k.trim()).filter(Boolean) : [];
        const count = kwArr.length;
        cnt.textContent = String(count);
        if (count === 0) {
          msg.textContent = '';
          msg.className = 'nu_status_msg';
        } else if (count < 3) {
          msg.textContent = `Te faltan ${3 - count} para tener una densidad ideal (Mínimo: 3)`;
          msg.className = 'nu_status_msg warning';
        } else if (count <= 5) {
          msg.textContent = `Excelente densidad de ${count}/5`;
          msg.className = 'nu_status_msg success';
        } else {
          msg.textContent = `Te pasaste por ${count - 5}. Máximo: 5`;
          msg.className = 'nu_status_msg error';
        }
      }
    };

    if (titleInp) listen(titleInp, 'input', updateTituloCounter);
    if (slugInp) listen(slugInp, 'input', updateSlugCounter);
    if (resumenInp) listen(resumenInp, 'input', updateResumenCounter);
    if (keywordsInp) listen(keywordsInp, 'input', updateKeywordsCounter);

    if (form) {
      listen(form, 'input', triggerDraftSave);
      
      listen(form, 'submit', async (e: Event) => {
        e.preventDefault();
        const activeBtn = document.activeElement as HTMLButtonElement;
        const btnSelector = (activeBtn && activeBtn.id === 'nu_submit_btn_aside') ? '#nu_submit_btn_aside' : '#nu_submit';
        
        let catVal = (document.getElementById('nu_cat_inp') as HTMLInputElement).value.trim();
        if (catVal) catVal = catVal.charAt(0).toUpperCase() + catVal.slice(1).toLowerCase();

        const titulo = (document.getElementById('nu_titulo') as HTMLInputElement).value.trim();
        const resumen = (document.getElementById('nu_resumen') as HTMLTextAreaElement).value.trim();
        const keywords = (document.getElementById('nu_keywords') as HTMLTextAreaElement).value.trim();
        const img = (document.getElementById('nu_img') as HTMLInputElement).value.trim();
        const imgTop = (document.getElementById('nu_img_top') as HTMLInputElement).value.trim();
        const contenidoMD = (document.getElementById('nu_contenido') as HTMLTextAreaElement).value.trim();
        const slug = slugInp.value.trim();
        const contenido = wiSanihtml(mdToHtml(contenidoMD));

        if (!titulo || !resumen || !catVal || !img || !contenidoMD) {
          Notificacion('Completa los campos obligatorios', 'warning');
          return;
        }
        if (contenidoMD.length < 10) {
          Notificacion('Contenido muy corto', 'warning');
          return;
        }
        if (!slug || slug.length < 3) {
          Notificacion('Slug inválido', 'warning');
          return;
        }

        const slugStatus = document.getElementById('nu_slug_status');
        if (!isEdit && slugStatus && slugStatus.classList.contains('err')) {
          Notificacion('Slug no disponible', 'error');
          return;
        }

        wiSpin(btnSelector, true, isEdit ? 'Guardando...' : 'Publicando...');

        try {
          const min = countWords(contenido).min;
          const readTime = `${min} min`;

          if (isEdit && editSlug) {
            await updateDoc(doc(db, 'blog', editSlug), {
              activo: (document.getElementById('nu_activo') as HTMLInputElement).checked,
              pin: (document.getElementById('nu_pin') as HTMLInputElement).checked,
              titulo,
              descripcion: resumen,
              categoria: catVal,
              contenido,
              contenidoMD,
              imagen: img,
              imagenTop: imgTop,
              tags,
              lecturaTM: readTime,
              metaSEO: { keywords },
              actualizado: serverTimestamp()
            });
            
            clearPostCache(editSlug);
            clearBlogCache();
             Mensaje('¡Publicación actualizada!', 'success');
            setTimeout(() => window.location.href = `/${editSlug}`, 1200);
          } else {
            const docSnap = await getDoc(doc(db, 'blog', slug));
            if (docSnap.exists()) {
              wiSpin(btnSelector, false);
              Notificacion('Slug existente', 'warning');
              return;
            }
            await setDoc(doc(db, 'blog', slug), {
              slug,
              activo: (document.getElementById('nu_activo') as HTMLInputElement).checked,
              pin: (document.getElementById('nu_pin') as HTMLInputElement).checked,
              usuario: u.usuario,
              email: u.email,
              userId: u.id,
              autor: u.nombre || u.usuario,
              titulo,
              descripcion: resumen,
              contenido,
              contenidoMD,
              categoria: catVal,
              imagen: img,
              imagenTop: imgTop,
              tags,
              vistas: 0,
              likes: 0,
              lecturaTM: readTime,
              metaSEO: { keywords },
              creado: serverTimestamp(),
              actualizado: serverTimestamp()
            });
            
            clearBlogCache();
            localStorage.removeItem(getDraftKey());
             Mensaje('¡Publicación creada! 🚀✨', 'success');
            setTimeout(() => window.location.href = `/${slug}`, 1200);
          }
        } catch (err) {
          console.error(err);
          Notificacion(isEdit ? 'Error al guardar' : 'Error al publicar', 'error');
          wiSpin(btnSelector, false);
        }
      });
    }

    // Slug generation on keypress/change disabled (now completed manually)

    if (slugInp && !isEdit) {
      listen(slugInp, 'input', () => {
        slugInp.value = slugInp.value.replace(/[^a-z0-9_-]/gi, s => s === ' ' ? '-' : '').toLowerCase().replace(/[-_]{2,}/g, '-');
        const slugStatus = document.getElementById('nu_slug_status');
        const v = slugInp.value;
        if (slugStatus) {
          if (v) {
            slugStatus.innerHTML = '<i class="fas fa-pen"></i> Escribiendo...';
            slugStatus.className = 'nu_slug_status';
          } else {
            slugStatus.innerHTML = '';
            slugStatus.className = 'nu_slug_status';
          }
        }
      });

      listen(slugInp, 'change', async () => {
        const v = slugInp.value;
        const slugStatus = document.getElementById('nu_slug_status');
        if (!slugStatus) return;
        if (!v) { slugStatus.innerHTML = ''; slugStatus.className = 'nu_slug_status'; return; }
        if (v.length < 3) {
          slugStatus.innerHTML = '<i class="fas fa-exclamation"></i> Muy corto';
          slugStatus.className = 'nu_slug_status err';
          return;
        }
        slugStatus.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        slugStatus.className = 'nu_slug_status';
        try {
          const docSnap = await getDoc(doc(db, 'blog', v));
          if (docSnap.exists()) {
            slugStatus.innerHTML = '<i class="fas fa-xmark"></i> Ya existe';
            slugStatus.className = 'nu_slug_status err';
          } else {
            slugStatus.innerHTML = '<i class="fas fa-check"></i> OK';
            slugStatus.className = 'nu_slug_status ok';
          }
        } catch (_) {
          slugStatus.innerHTML = '';
        }
      });

      // Reset slug button listener removed (button removed from UI)
    }

    // Character counter for resumen is handled automatically in setupEvents

    // Content area change
    const contentArea = document.getElementById('nu_contenido');
    if (contentArea) {
      listen(contentArea, 'input', updCount);
    }

    // Image previews
    const imgInp = document.getElementById('nu_img') as HTMLInputElement;
    if (imgInp) {
      listen(imgInp, 'input', () => {
        clearTimeout(iT);
        iT = setTimeout(() => {
          const val = imgInp.value.trim();
          const prev = document.getElementById('nu_img_prev');
          const el = document.getElementById('nu_img_el') as HTMLImageElement;
          if (!val) { prev?.classList.add('dpn'); return; }
          if (el && prev) {
            el.src = val;
            el.onload = () => prev.classList.remove('dpn');
            el.onerror = () => prev.classList.add('dpn');
          }
        }, 600);
      });
    }

    const imgClear = document.getElementById('nu_img_clear');
    if (imgClear && imgInp) {
      listen(imgClear, 'click', () => {
        imgInp.value = '';
        imgInp.dispatchEvent(new Event('input'));
      });
    }

    const imgTopInp = document.getElementById('nu_img_top') as HTMLInputElement;
    if (imgTopInp) {
      listen(imgTopInp, 'input', () => {
        clearTimeout(iT2);
        iT2 = setTimeout(() => {
          const val = imgTopInp.value.trim();
          const prev = document.getElementById('nu_img_top_prev');
          const el = document.getElementById('nu_img_top_el') as HTMLImageElement;
          if (!val) { prev?.classList.add('dpn'); return; }
          if (el && prev) {
            el.src = val;
            el.onload = () => prev.classList.remove('dpn');
            el.onerror = () => prev.classList.add('dpn');
          }
        }, 600);
      });
    }

    const imgTopClear = document.getElementById('nu_img_top_clear');
    if (imgTopClear && imgTopInp) {
      listen(imgTopClear, 'click', () => {
        imgTopInp.value = '';
        imgTopInp.dispatchEvent(new Event('input'));
      });
    }

    // Tags list input keydown
    const tagsInp = document.getElementById('nu_tags_inp') as HTMLInputElement;
    if (tagsInp) {
      listen(tagsInp, 'keydown', (e: Event) => {
        const keyEvent = e as KeyboardEvent;
        if (keyEvent.key === 'Enter' || keyEvent.key === ',') {
          keyEvent.preventDefault();
          const items = tagsInp.value.toLowerCase().split(',').map(t => t.trim().replace(/\s+/g, '_')).filter(Boolean);
          items.forEach(t => {
            if (!tags.includes(t) && tags.length < 8) tags.push(t);
          });
          renderTags();
          tagsInp.value = '';
          saveDraft();
        }
      });
    }

    // Markdown tools toolbar functionality
    const tools = document.querySelectorAll('.nu_tool');
    tools.forEach(tool => {
      listen(tool, 'click', () => {
        const tag = tool.getAttribute('data-tag');
        if (!tag || !contentArea) return;
        const ta = contentArea as HTMLTextAreaElement;
        const s = ta.selectionStart;
        const e = ta.selectionEnd;
        const selection = ta.value.substring(s, e) || 'texto';
        let ins = tag.replace('texto', selection).replace('cita', selection);
        if (tag.includes('- item')) ins = '- item\n- item2'; // default item list
        ta.value = ta.value.substring(0, s) + ins + ta.value.substring(e);
        ta.focus();
        ta.selectionStart = s;
        ta.selectionEnd = s + ins.length;
        updCount();
        saveDraft();
      });
    });

    // Editor Tabs (Edit / Preview)
    const tabs = document.querySelectorAll('.nu_tab');
    tabs.forEach(tab => {
      listen(tab, 'click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const mode = tab.getAttribute('data-tab');
        const prevHtml = document.getElementById('nu_prev_html');
        const textarea = document.getElementById('nu_contenido');
        if (mode === 'prev' && prevHtml && textarea) {
          prevHtml.innerHTML = wiSanihtml(mdToHtml((textarea as HTMLTextAreaElement).value));
          prevHtml.classList.remove('dpn');
          textarea.classList.add('dpn');
        } else if (prevHtml && textarea) {
          prevHtml.classList.add('dpn');
          textarea.classList.remove('dpn');
        }
      });
    });

    // Chip removals and suggestions click delegation
    listen(document, 'click', (e: Event) => {
      const target = e.target as HTMLElement;
      
      // Remove tag
      const tagRm = target.closest('.nu_tag_rm');
      if (tagRm) {
        const idx = parseInt(tagRm.getAttribute('data-i') || '0');
        tags.splice(idx, 1);
        renderTags();
        saveDraft();
        return;
      }

      // Suggest category and tag click handlers removed
    });
  };

  const initDashboard = async () => {
    cleanup();

    const u = await protegerRuta(['usuario', 'editor', 'gestor', 'admin']);
    if (!u) return;

    // Actualizar datos del Autor
    const autorNombreEl = document.getElementById('nu_autor_nombre');
    const autorEmailEl = document.getElementById('nu_autor_email');
    if (autorNombreEl) autorNombreEl.textContent = u.nombre || u.usuario || 'Anónimo';
    if (autorEmailEl) autorEmailEl.textContent = u.email || '';

    // Cargar dominio en label del slug
    const domainLblEl = document.getElementById('nu_domain_lbl');
    if (domainLblEl) domainLblEl.textContent = linkweb.replace('https://','').replace('http://','') + '/';

    editSlug = getEditSlug();
    isEdit = !!editSlug;

    // Adaptar títulos en edición
    const mainTitleEl = document.getElementById('nu_main_title');
    const editInfoEl = document.getElementById('nu_edit_info');
    const submitBtnEl = document.getElementById('nu_submit');
    const submitBtnAsideEl = document.getElementById('nu_submit_btn_aside');
    const btnLblEl = document.getElementById('nu_btn_lbl');
    const btnLblAsideEl = document.getElementById('nu_btn_lbl_aside');
    const cardPubLblEl = document.getElementById('nu_card_pub_lbl');
    const slugInp = document.getElementById('nu_slug_inp') as HTMLInputElement;
    const viewPostBtnEl = document.getElementById('nu_view_post_btn');

    if (isEdit) {
      if (mainTitleEl) mainTitleEl.innerHTML = `<i class="fas fa-pen"></i> Editar publicación`;
      if (editInfoEl) editInfoEl.innerHTML = `Editando: <strong>${editSlug}</strong> ✏️`;
      if (btnLblEl) btnLblEl.textContent = 'Guardar';
      if (btnLblAsideEl) btnLblAsideEl.textContent = 'Guardar cambios';
      if (cardPubLblEl) cardPubLblEl.textContent = 'Actualizar';
      if (slugInp) slugInp.readOnly = true;
      if (viewPostBtnEl) {
        viewPostBtnEl.classList.remove('dpn');
        viewPostBtnEl.setAttribute('href', `/${editSlug}`);
      }
      
      const resetSlugBtn = document.getElementById('nu_slug_reset');
      if (resetSlugBtn) resetSlugBtn.remove();
      const slugStatusEl = document.getElementById('nu_slug_status');
      if (slugStatusEl) slugStatusEl.innerHTML = '<span class="ok"><i class="fas fa-lock"></i> Slug bloqueado (edición)</span>';
    }

    cargarSugerencias();
    setupEvents(u);

    // Rellenar formulario (Edición o Draft)
    if (isEdit && editSlug) {
      try {
        const result = await getPost(editSlug, true);
        if (result?.data) {
          const p = result.data;
          (document.getElementById('nu_titulo') as HTMLInputElement).value = p.titulo || '';
          slugInp.value = p.slug || p.id || '';
          (document.getElementById('nu_resumen') as HTMLTextAreaElement).value = p.resumen || '';
          (document.getElementById('nu_keywords') as HTMLTextAreaElement).value = p.keywords || '';
          (document.getElementById('nu_contenido') as HTMLTextAreaElement).value = p.contenidoMd || p.contenido || '';
          (document.getElementById('nu_cat_inp') as HTMLInputElement).value = p.categoria || '';
          (document.getElementById('nu_img') as HTMLInputElement).value = p.imagen || '';
          (document.getElementById('nu_img_top') as HTMLInputElement).value = p.imagenTop || '';
          (document.getElementById('nu_activo') as HTMLInputElement).checked = p.activo !== false;
          (document.getElementById('nu_pin') as HTMLInputElement).checked = !!p.pin;

          tags = Array.isArray(p.tags) ? [...p.tags] : [];
          renderTags();

          if (p.imagen) {
            const imgEl = document.getElementById('nu_img_el') as HTMLImageElement;
            const prevEl = document.getElementById('nu_img_prev');
            if (imgEl && prevEl) { imgEl.src = p.imagen; prevEl.classList.remove('dpn'); }
          }
          if (p.imagenTop) {
            const imgTopEl = document.getElementById('nu_img_top_el') as HTMLImageElement;
            const prevTopEl = document.getElementById('nu_img_top_prev');
            if (imgTopEl && prevTopEl) { imgTopEl.src = p.imagenTop; prevTopEl.classList.remove('dpn'); }
          }

          // Counters will be triggered at the end of initDashboard
          updCount();
        }
      } catch (err) {
        console.error('Error al cargar post en edición:', err);
        Notificacion('Error cargando post', 'error');
      }
    } else {
      // Intentar cargar draft guardado
      try {
        const draftKey = getDraftKey();
        const d = JSON.parse(localStorage.getItem(draftKey) || 'null');
        if (d) {
          (document.getElementById('nu_titulo') as HTMLInputElement).value = d.titulo || '';
          if (slugInp) slugInp.value = d.slug || '';
          (document.getElementById('nu_resumen') as HTMLTextAreaElement).value = d.resumen || '';
          (document.getElementById('nu_keywords') as HTMLTextAreaElement).value = d.keywords || '';
          (document.getElementById('nu_cat_inp') as HTMLInputElement).value = d.cat || '';
          (document.getElementById('nu_contenido') as HTMLTextAreaElement).value = d.content || '';
          
          const imgInp = document.getElementById('nu_img') as HTMLInputElement;
          const imgTopInp = document.getElementById('nu_img_top') as HTMLInputElement;
          if (imgInp) imgInp.value = d.img || '';
          if (imgTopInp) imgTopInp.value = d.imgTop || '';

          if (d.img) {
            const imgEl = document.getElementById('nu_img_el') as HTMLImageElement;
            const prevEl = document.getElementById('nu_img_prev');
            if (imgEl && prevEl) { imgEl.src = d.img; prevEl.classList.remove('dpn'); }
          }
          if (d.imgTop) {
            const imgTopEl = document.getElementById('nu_img_top_el') as HTMLImageElement;
            const prevTopEl = document.getElementById('nu_img_top_prev');
            if (imgTopEl && prevTopEl) { imgTopEl.src = d.imgTop; prevTopEl.classList.remove('dpn'); }
          }

          if (d.tags) { tags = d.tags; renderTags(); }
          
          updCount();
        }
      } catch (_) {}
    }

    // Trigger initial counter updates after populating values
    ['nu_titulo', 'nu_slug_inp', 'nu_resumen', 'nu_keywords'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.dispatchEvent(new Event('input'));
    });
  };

  document.addEventListener('astro:page-load', initDashboard);
  document.addEventListener('astro:before-preparation', cleanup);
</script>
