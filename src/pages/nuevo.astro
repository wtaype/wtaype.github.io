---
import Layout from '../layouts/Layout.astro';
import { app, id } from '../wii.js';
---

<style is:global>
@import "../lib/blog/post.css";

/* ── 1. WRAP & HEAD ──────────────────────────────── */
.nu_wrap {
  margin: 0 auto;
  padding: 0 1vh;
}
.nu_head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2vh;
  padding-bottom: 1.5vh;
  border-bottom: 1px solid var(--brd);
  flex-wrap: wrap;
  gap: 1vh;
}
.nu_head_left h1 {
  font-size: var(--fz_l2);
  font-weight: 800;
  color: var(--tx1);
  display: flex;
  align-items: center;
  gap: 0.8vh;
  margin: 0;
}
.nu_head_left h1 i { color: var(--mco); }
.nu_head_left p { color: var(--tx3); font-size: var(--fz_m2); margin: 0.3vh 0 0; }
.nu_head_right { display: flex; gap: 0.8vh; align-items: center; }

/* ── 2. LAYOUT 2 COLUMNAS ────────────────────────── */
.nu_layout {
  display: grid;
  grid-template-columns: 1fr 26%;
  gap: 2vw;
  align-items: start;
}
.nu_left, .nu_right {
  display: flex;
  flex-direction: column;
  gap: 1.5vh;
}

/* ── 3. CARDS ────────────────────────────────────── */
.nu_card {
  background: var(--wb);
  border-radius: 1.8vh;
  padding: 3vh;
  border: 1px solid var(--brd);
  box-shadow: 0 4px 12px rgba(0,0,0,.02);
  display: flex;
  flex-direction: column;
  gap: 0;
}
.nu_card_title {
  font-size: var(--fz_m2);
  font-weight: 700;
  color: var(--tx1);
  display: flex;
  align-items: center;
  gap: 0.6vh;
  padding-bottom: 0.8vh;
  margin-bottom: 0.4vh;
}
.nu_card_title i { color: var(--mco); }
.nu_hint {
  color: var(--tx3);
  font-size: var(--fz_s3);
  font-weight: 400;
}
.nu_card_title_row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 0.8vh;
  margin-bottom: 0.4vh;
  flex-wrap: wrap;
  gap: 0.5vh;
}
.nu_card_title_row > span {
  font-size: var(--fz_m2);
  font-weight: 700;
  color: var(--tx1);
  display: flex;
  align-items: center;
  gap: 0.6vh;
}
.nu_card_title_row > span i { color: var(--mco); }
.nu_counter {
  text-align: right;
  font-size: var(--fz_s3);
  color: var(--tx3);
}
.nu_content_footer {
  display: flex;
  justify-content: space-between;
  padding-top: 0.6vh;
  border-top: 1px solid var(--brd);
}
.nu_content_footer span {
  font-size: var(--fz_s3);
  color: var(--tx3);
  display: flex;
  align-items: center;
  gap: 0.4vh;
}
.nu_content_footer i { color: var(--mco); }

/* Input título grande */
.nu_titulo_inp {
  font-size: var(--fz_m5);
  font-weight: 700;
  padding: 1.2vh 1.5vh;
  border-radius: 1vh;
}

/* Base global de Inputs (Estilo Perfil) */
.nu_card input[type="text"],
.nu_card input[type="url"],
.nu_card textarea {
  width: 100%;
  padding: 1.2vh 1.5vh;
  border: 2px solid var(--bg4);
  border-radius: 1vh;
  background: var(--bg);
  color: var(--tx);
  font-family: var(--ff_P);
  font-size: var(--fz_m1);
  transition: all .3s;
}
.nu_card input[type="text"]:focus,
.nu_card input[type="url"]:focus,
.nu_card textarea:focus {
  border-color: var(--mco);
  outline: none;
  background: var(--wb);
}

/* Rejilla para SEO (Resumen y Keywords) */
.nu_grid_seo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5vw;
}

@media (max-width: 900px) {
  .nu_grid_seo { grid-template-columns: 1fr; }
}

/* ── 4. SLUG EDITABLE ────────────────────────────── */
.nu_slug_box {
  display: flex;
  align-items: center;
  background: var(--bg4);
  border: 1px solid var(--brd);
  border-radius: 0.7vh;
  overflow: hidden;
  transition: border-color var(--tr_f);
  margin-top: 1.5vh;
}
.nu_slug_label {
  display: flex;
  align-items: center;
  gap: 0.4vh;
  padding: 0.8vh 1vh;
  font-size: var(--fz_s4);
  font-weight: 600;
  color: var(--mco);
  white-space: nowrap;
  border-right: 1px solid var(--brd);
  background: var(--bg5);
}
.nu_slug_box input {
  flex: 1;
  border: none;
  border-radius: 0;
  background: transparent;
  font-family: 'Courier New', monospace;
  font-size: var(--fz_m1);
  color: var(--tx1);
  font-weight: 600;
  padding: 0.8vh 1vh;
  box-shadow: none !important;
}
.nu_slug_btn {
  padding: 0.8vh 1.2vh;
  background: transparent;
  border: none;
  border-left: 1px solid var(--brd);
  color: var(--tx3);
  cursor: pointer;
  transition: all var(--tr_f);
  border-radius: 0;
}
.nu_slug_btn:hover { background: var(--mco); color: var(--txa); }
.nu_slug_status {
  font-size: var(--fz_s4);
  display: flex;
  align-items: center;
  gap: 0.4vh;
  min-height: 2vh;
  padding: 0 0.3vh;
  transition: all var(--tr_f);
  margin-top: 0.5vh;
}
.nu_slug_status.ok { color: var(--success); }
.nu_slug_status.err { color: var(--error); }

/* ── 5. TOOLBAR HTML ─────────────────────────────── */
.nu_toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5vh;
  padding: 0.6vh;
  background: var(--bg4);
  border-radius: 0.6vh;
  border: 1px solid var(--brd);
  margin-bottom: 1vh;
}
.nu_toolbar_grp {
  display: flex;
  gap: 0.4vh;
}
.nu_toolbar_grp.border_right {
  border-right: 1px solid var(--brd);
  padding-right: 0.6vh;
  margin-right: 0.2vh;
}
.nu_toolbar_grp.border_left {
  border-left: 1px solid var(--brd);
  padding-left: 0.6vh;
  margin-left: 0.2vh;
}
.nu_tool_h3_span {
  font-size: 0.85em;
  font-weight: bold;
}
.nu_tool .fa-briefcase { color: var(--mco); }
.nu_tool .fa-lightbulb { color: #FFC107; }
.nu_tool .fa-chart-line { color: #0edeFF; }
.nu_tool .fa-user-tie { color: #e0a910; }
.nu_tool .fa-heart { color: #fe0149; }
.nu_tool .fa-star { color: #FFB636; }
.nu_tool .fa-circle-check { color: #3cd741; }
.nu_tool .fa-circle-xmark { color: #ff3849; }

.nu_tool {
  width: 3.6vh;
  height: 3.6vh;
  padding: 0;
  background: var(--wb);
  color: var(--tx2);
  border: 1px solid var(--brd);
  border-radius: 0.5vh;
  font-size: var(--fz_m1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--tr_f);
}
.nu_tool:hover {
  background: var(--mco);
  color: var(--txa);
  border-color: var(--mco);
  transform: translateY(-0.2vh);
}

/* ── 6. EDITOR & PREVIEW ─────────────────────────── */
.nu_editor_tabs {
  display: flex;
  gap: 0.4vh;
}
.nu_tab {
  padding: 0.5vh 1.2vh;
  background: var(--bg4);
  color: var(--tx3);
  border: 1px solid var(--brd);
  border-radius: 0.6vh;
  font-size: var(--fz_s4);
  cursor: pointer;
  transition: all var(--tr_f);
  display: flex;
  align-items: center;
  gap: 0.4vh;
}
.nu_tab.active, .nu_tab:hover {
  background: var(--mco);
  color: var(--txa);
  border-color: var(--mco);
}
.nu_code {
  font-family: 'Courier New', monospace;
  font-size: var(--fz_s4);
  background: var(--bg);
  color: var(--txe);
  min-height: 36vh;
  line-height: 1.7;
  resize: vertical;
  border-radius: 0.6vh;
}
.nu_html_prev {
  min-height: 20vh;
  padding: 1.5vh;
  background: var(--wb);
  border-radius: 1vh;
  border: 1px solid var(--brd);
  color: var(--tx);
  line-height: 1.9;
  font-size: var(--fz_m2);
  overflow-y: auto;
  margin-top: 1vh;
  overflow-wrap: break-word;
}
.nu_image_input_group {
  display: flex;
  flex-direction: column;
  gap: 1vh;
  margin-bottom: 1.5vh;
}
.nu_image_input_group.no_margin {
  margin-bottom: 0;
}
.nu_image_field_label {
  font-size: var(--fz_s4);
  color: var(--tx2);
  font-weight: 600;
}

/* ── 7. IMAGEN DESTACADA ─────────────────────────── */
.nu_img_prev {
  position: relative;
  margin-top: 0.5vh;
  border-radius: 1vh;
  overflow: hidden;
  border: 1px solid var(--brd);
}
.nu_img_prev img {
  width: 100%;
  height: 20vh;
  object-fit: cover;
  display: block;
  border-radius: 0;
}
.nu_img_clear {
  position: absolute;
  top: 0.8vh;
  right: 0.8vh;
  width: 3.5vh;
  height: 3.5vh;
  padding: 0;
  background: rgba(0,0,0,0.55);
  color: #fff;
  border: none;
  border-radius: 50%;
  font-size: var(--fz_m2);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all var(--tr_f);
}
.nu_img_clear:hover { background: var(--error); }

/* ── 8. SUGERENCIAS Y CHIPS (Categorías y Tags) ──────────────────────────── */
.nu_sug_box {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6vh;
  margin-top: 0.8vh;
}
.nu_sug_chip {
  padding: 0.4vh 1vh;
  background: var(--bg4);
  border: 1px solid var(--brd);
  border-radius: 5vh;
  font-size: var(--fz_s4);
  color: var(--tx3);
  cursor: pointer;
  transition: all var(--tr_f);
}
.nu_sug_chip:hover {
  background: color-mix(in srgb, var(--mco) 10%, transparent);
  border-color: var(--mco);
  color: var(--mco);
}

/* ── 9. TAGS CHIPS ───────────────────────────────── */
.nu_tags_box {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5vh;
  min-height: 2vh;
  padding: 0.4vh 0;
}
.nu_tag_chip {
  display: flex;
  align-items: center;
  gap: 0.4vh;
  padding: 0.4vh 1vh;
  background: var(--bg5);
  color: var(--mco);
  border-radius: 2vh;
  font-size: var(--fz_s4);
  font-weight: 600;
  border: 1px solid var(--mco);
}
.nu_tag_rm {
  cursor: pointer;
  font-size: var(--fz_s3);
  color: var(--tx3);
  transition: color var(--tr_f);
  padding: 0;
}
.nu_tag_rm:hover { color: var(--error); }

/* ── 10. CHECKS & PUBLICAR ───────────────────────── */
.nu_card_publish { border: 2px solid var(--mco); }
.nu_card_publish .nu_card_title { color: var(--mco); }
.nu_publish_opts { display: flex; flex-direction: column; gap: 0.6vh; }
.nu_check_l {
  display: flex !important;
  align-items: center;
  gap: 0.8vh;
  cursor: pointer;
  padding: 1.2vh 1.5vh;
  background: var(--wb);
  border-radius: 1vh;
  border: 2px solid var(--bg4);
  transition: all var(--tr_f);
  margin: 0;
}
.nu_check_l:hover { background: var(--bg5); border-color: var(--mco); }
.nu_check_l input { width: auto; }
.nu_check_l span {
  display: flex;
  align-items: center;
  gap: 0.5vh;
  font-size: var(--fz_m1);
  font-weight: 500;
  color: var(--tx1);
}
.nu_check_l i { color: var(--mco); }

/* ── 11. BOTONES ─────────────────────────────────── */
.nu_btn_submit {
  padding: 1.2vh 2.5vh;
  background: var(--mco);
  color: var(--txa);
  border: none;
  border-radius: 0.8vh;
  font-size: var(--fz_m3);
  font-weight: 700;
  cursor: pointer;
  transition: all var(--tr_m);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.6vh;
  box-shadow: 0 0.4vh 1.5vh var(--bg5);
}
.nu_btn_submit:hover { transform: translateY(-0.3vh); box-shadow: 0 0.8vh 2vh var(--bg5); }
.nu_btn_full { width: 100%; margin-top: 0.5vh; }
.nu_btn_outline {
  padding: 1vh 1.8vh;
  background: transparent;
  color: var(--mco);
  border: 1.5px solid var(--mco);
  border-radius: 0.8vh;
  font-size: var(--fz_m2);
  font-weight: 600;
  cursor: pointer;
  transition: all var(--tr_f);
  display: flex;
  align-items: center;
  gap: 0.5vh;
}
.nu_btn_outline:hover { background: var(--mco); color: var(--txa); }

/* ── 12. AUTOR INFO ──────────────────────────────── */
.nu_autor_info {
  display: flex;
  align-items: center;
  gap: 1.2vh;
  padding: 0.8vh;
  background: var(--bg4);
  border-radius: 0.8vh;
}
.nu_autor_av i {
  font-size: var(--fz_x1);
  color: var(--mco);
  opacity: 0.7;
}
.nu_autor_info strong {
  display: block;
  font-size: var(--fz_m2);
  color: var(--tx1);
}
.nu_autor_info span {
  font-size: var(--fz_s3);
  color: var(--tx3);
}

/* ── 13. ACCESO RESTRINGIDO ──────────────────────── */
.nu_err { gap: 2vh; min-height: 50vh; color: var(--tx3); }
.nu_err i { font-size: var(--fz_x3); color: var(--mco); opacity: 0.5; }
.nu_err h2 { font-size: var(--fz_l2); color: var(--tx1); }
.nu_btn {
  padding: 1.2vh 3vh;
  background: var(--mco);
  color: var(--txa);
  border-radius: 1vh;
  font-weight: 600;
  font-size: var(--fz_m3);
  transition: all var(--tr_f);
  display: flex;
  align-items: center;
  gap: 0.6vh;
}
.nu_btn:hover { transform: translateY(-0.2vh); }

/* ── 14. RESPONSIVE ──────────────────────────────── */
@media (max-width: 900px) {
  .nu_layout { grid-template-columns: 1fr; }
  .nu_right { order: -1; }
  .nu_card_publish { display: none; } /* ya hay botón en el head */
  .nu_wrap { padding: 1vh 0 6vh; }
}
@media (max-width: 600px) {
  .nu_head { flex-direction: column; align-items: flex-start; }
  .nu_cats_grid { grid-template-columns: 1fr 1fr 1fr; }
  .nu_code { min-height: 28vh; }
}
.nu_counter_box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--fz_s3);
  color: var(--tx3);
  margin-top: 0.6vh;
}
.nu_status_msg {
  font-weight: 600;
  font-size: var(--fz_s3);
  transition: color var(--tr_f);
}
.nu_status_msg.warning { color: var(--warning); }
.nu_status_msg.success { color: var(--success); }
.nu_status_msg.error { color: var(--error); }
</style>

<Layout title="Nueva publicación" name={app} robots="noindex, nofollow">
  <div class="nu_wrap">
    <div class="nu_head">
      <div class="nu_head_left">
        <h1 id="nu_main_title"><i class="fas fa-laptop-code"></i> Nueva publicación</h1>
        <p id="nu_edit_info"></p>
      </div>
      <div class="nu_head_right">
        <a href="/blog" id="nu_view_post_btn" class="nu_btn_outline dpn" title="Ver post"><i class="fas fa-eye"></i> Ver</a>
        <button type="submit" form="nu_form" id="nu_submit" class="nu_btn_submit"><i class="fas fa-paper-plane"></i> <span id="nu_btn_lbl">Publicar</span></button>
      </div>
    </div>
    
    <form id="nu_form" autocomplete="off">
      <div class="nu_layout">
        <div class="nu_left">
          
          <div class="nu_card">
            <div class="nu_card_title"><i class="fas fa-heading"></i> Título</div>
            <input id="nu_titulo" type="text" class="nu_titulo_inp" placeholder="Escribe un título impactante... (Mínimo: 35, Máximo: 47)" maxlength="47" required/>
            <div class="nu_counter_box">
              <span id="nu_titulo_msg" class="nu_status_msg"></span>
              <span><span id="nu_titulo_cnt">0</span>/47</span>
            </div>
            <div class="nu_slug_box">
              <span class="nu_slug_label"><i class="fas fa-link"></i> <span id="nu_domain_lbl">{id}.vercel.app/</span></span>
              <input id="nu_slug_inp" type="text" placeholder="novedades-ia" maxlength="32" spellcheck="false"/>
            </div>
            <div class="nu_counter_box">
              <span id="nu_slug_msg" class="nu_status_msg"></span>
              <span><span id="nu_slug_cnt">0</span>/32</span>
            </div>
            <div id="nu_slug_status" class="nu_slug_status"></div>
          </div>
          
          <div class="nu_grid_seo">
            <div class="nu_card">
              <div class="nu_card_title"><i class="fas fa-align-left"></i> Resumen (Meta Description)</div>
              <textarea id="nu_resumen" rows="3" maxlength="150" placeholder="Describe en pocas palabras... (Mínimo: 100, Máximo: 150)"></textarea>
              <div class="nu_counter_box">
                <span id="nu_resumen_msg" class="nu_status_msg"></span>
                <span><span id="nu_resumen_cnt">0</span>/150</span>
              </div>
            </div>
            <div class="nu_card">
              <div class="nu_card_title"><i class="fas fa-search"></i> Palabras Clave (Meta Keywords)</div>
              <textarea id="nu_keywords" rows="3" maxlength="100" placeholder={`ia, programacion, javascript, python, frontend, ${id}...`}></textarea>
              <div class="nu_counter_box">
                <span id="nu_keywords_msg" class="nu_status_msg"></span>
                <span><span id="nu_keywords_cnt">0</span>/5 palabras clave</span>
              </div>
            </div>
          </div>

          <div class="nu_card nu_card_editor">
            <div class="nu_card_title_row">
              <span><i class="fas fa-code"></i> Contenido Markdown</span>
              <div class="nu_editor_tabs">
                <button type="button" class="nu_tab active" data-tab="edit"><i class="fas fa-code"></i> Editor</button>
                <button type="button" class="nu_tab" data-tab="prev"><i class="fas fa-eye"></i> Preview</button>
              </div>
            </div>
            <div class="nu_toolbar">
              <div class="nu_toolbar_grp border_right">
                <button type="button" class="nu_tool" data-tag="**texto**" title="Negrita"><i class="fas fa-bold"></i></button>
                <button type="button" class="nu_tool" data-tag="*texto*" title="Cursiva"><i class="fas fa-italic"></i></button>
                <button type="button" class="nu_tool" data-tag="~~texto~~" title="Tachado"><i class="fas fa-strikethrough"></i></button>
              </div>
              <div class="nu_toolbar_grp border_right">
                <button type="button" class="nu_tool" data-tag="## Título H2" title="Subtítulo (H2)"><i class="fas fa-heading"></i></button>
                <button type="button" class="nu_tool" data-tag="### Título H3" title="Sección (H3)"><span class="nu_tool_h3_span">H3</span></button>
              </div>
              <div class="nu_toolbar_grp border_right">
                <button type="button" class="nu_tool" data-tag="- item" title="Lista"><i class="fas fa-list-ul"></i></button>
                <button type="button" class="nu_tool" data-tag="- [ ] tarea" title="Checklist"><i class="fas fa-check-square"></i></button>
                <button type="button" class="nu_tool" data-tag="> cita" title="Citar"><i class="fas fa-quote-right"></i></button>
                <button type="button" class="nu_tool" data-tag="&#10;---&#10;" title="Separador"><i class="fas fa-minus"></i></button>
              </div>
              <div class="nu_toolbar_grp">
                <button type="button" class="nu_tool" data-tag="`código`" title="Código"><i class="fas fa-code"></i></button>
                <button type="button" class="nu_tool" data-tag="![desc](url)" title="Imagen"><i class="fas fa-image"></i></button>
                <button type="button" class="nu_tool" data-tag="[texto](url)" title="Enlace"><i class="fas fa-link"></i></button>
              </div>
              <div class="nu_toolbar_grp border_left">
                <button type="button" class="nu_tool" data-tag=":maletin:" title="Maletín Profesional"><i class="fas fa-briefcase"></i></button>
                <button type="button" class="nu_tool" data-tag=":foco:" title="Idea / Foco"><i class="fas fa-lightbulb"></i></button>
                <button type="button" class="nu_tool" data-tag=":grafico:" title="Gráfico de Crecimiento"><i class="fas fa-chart-line"></i></button>
                <button type="button" class="nu_tool" data-tag=":usuario:" title="Profesional / Empleo"><i class="fas fa-user-tie"></i></button>
                <button type="button" class="nu_tool" data-tag=":corazon:" title="Corazón"><i class="fas fa-heart"></i></button>
                <button type="button" class="nu_tool" data-tag=":estrella:" title="Estrella"><i class="fas fa-star"></i></button>
                <button type="button" class="nu_tool" data-tag=":si:" title="Check Verde"><i class="fas fa-circle-check"></i></button>
                <button type="button" class="nu_tool" data-tag=":no:" title="X Roja"><i class="fas fa-circle-xmark"></i></button>
              </div>
            </div>
