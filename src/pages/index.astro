<script>
  import { wiVista, wiTip } from '../lib/widev.js';

  let roleInterval: any = null;

  const cleanup = () => {
    if (roleInterval) {
      clearInterval(roleInterval);
      roleInterval = null;
    }
  };

  const animarContadores = () => {
    const statCards = document.querySelectorAll('.stat_card');
    if (!statCards.length) return;

    statCards.forEach((card) => {
      const numEl = card.querySelector('.stat_number');
      if (!numEl) return;
      const target = Number(numEl.getAttribute('data-target')) || 0;
      const step = target / 50;
      let current = 0;

      const t = setInterval(() => {
        current = Math.min(current + step, target);
        numEl.textContent = current < target ? String(Math.floor(current)) : `${target}+`;
        if (current >= target) clearInterval(t);
      }, 30);
    });
  };

  const checkSession = () => {
    const wi = localStorage.getItem('wiSmile');
    // Si necesitas lógica adicional de botones admin en el cliente, se inyecta aquí.
  };

  const init = () => {
    cleanup();
    wiTip(); // Inicializar el módulo de tooltips (widev.js)

    // 1. Rotador de Roles
    let idx = 0;
    const roles = document.querySelectorAll('.hero_roles .role');
    if (roles.length) {
      roleInterval = setInterval(() => {
        roles[idx].classList.remove('active');
        idx = (idx + 1) % roles.length;
        roles[idx].classList.add('active');
      }, 2500);
    }

    // 2. Animación de Contadores al entrar en vista
    wiVista('.hero_stats', animarContadores, { once: true });

    // 3. Stagger de Tarjetas de Acerca de Mí
    wiVista('.about_card', (el: any, i: any) => {
      setTimeout(() => el.classList.add('visible'), i * 150);
    }, { once: true, threshold: 0.05 });

    // 4. Stagger del Stack Tecnológico
    wiVista('.stack_pill', (el: any, i: any) => {
      setTimeout(() => el.classList.add('visible'), i * 50);
    }, { once: true, threshold: 0.05 });

    // 5. Stagger de Servicios
    wiVista('.servicio_card', (el: any, i: any) => {
      setTimeout(() => el.classList.add('visible'), i * 100);
    }, { once: true, threshold: 0.05 });

    // 6. Fade de la sección CTA
    wiVista('.cta_section', (el: any) => el.classList.add('visible'), { once: true });

    checkSession();
  };

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-preparation', cleanup);
</script>