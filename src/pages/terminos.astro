<script>
  import { app } from '../wii.js';

  // ⚡ INIT
  const initTerminos = () => {
    // Animación de entrada para los elementos wi_fadeUp
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.wi_fadeUp').forEach(el => {
      observer.observe(el);
    });

    // Smooth scroll para índice
    document.querySelectorAll('.tm_index_item').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            window.scrollTo({ 
              top: target.getBoundingClientRect().top + window.scrollY - 90, 
              behavior: 'smooth' 
            });
          }
        }
      });
    });

    console.log('📜 ' + app + ' Términos cargados');
    (window as any).__WIREADY__ = true;
  };

  document.addEventListener('astro:page-load', initTerminos);
</script>