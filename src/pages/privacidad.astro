---
import Layout from '../layouts/Layout.astro';
import { app } from '../wii.js';
import { seo } from '../lib/seo.js';
const year = () => new Date().getFullYear();
---

<style is:global>
/* =========================================================================
   CSS PREMIUM
   ========================================================================= */

@keyframes ac_float {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(30px, -50px) scale(1.1); }
  66% { transform: translate(-20px, 20px) scale(0.9); }
}

@keyframes ac_pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.2); }
}

.wi_fadeUp {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.wi_fadeUp.visible {
  opacity: 1;
  transform: translateY(0);
}

#wimain {
  opacity: 1 !important;
}

.ac_wrap {
  width: 100%;
  overflow-x: hidden;
  background: color-mix(in srgb, var(--mco) 3%, var(--bg));
  color: var(--tx);
  font-family: var(--ff_P);
}

/* ── HERO ── */
.ac_hero {
  position: relative;
  min-height: 90vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10vh 5vw;
  overflow: hidden;
}

.ac_hero_orb {
  position: absolute;
  filter: blur(80px);
  z-index: 0;
  border-radius: 50%;
  pointer-events: none;
}

.ac_orb1 { width: 40vw; height: 40vw; background: rgba(14, 190, 255, 0.15); top: -10vh; right: -5vw; animation: ac_float 20s infinite linear; }
.ac_orb2 { width: 35vw; height: 35vw; background: rgba(255, 92, 105, 0.12); bottom: -10vh; left: -5vw; animation: ac_float 25s infinite linear reverse; }
.ac_orb3 { width: 25vw; height: 25vw; background: rgba(112, 0, 255, 0.1); top: 30%; left: 40%; animation: ac_pulse 15s infinite ease-in-out; }

.ac_hero_body {
  position: relative;
  z-index: 1;
  text-align: center;
  max-width: 800px;
}

.ac_hero_badge {
  display: inline-flex;
  align-items: center;
  gap: 1vh;
  padding: 0.8vh 2vh;
  background: var(--wb);
  border: 1px solid var(--brd);
  border-radius: 4vh;
  font-size: var(--fz_s2);
  font-weight: 600;
  color: var(--tx3);
  margin-bottom: 3vh;
}
.ac_hero_badge i { color: var(--cielo); }

.ac_hero_tit {
  font-size: clamp(3rem, 10vw, 5.5rem);
  font-weight: 900;
  line-height: 0.9;
  margin-bottom: 3vh;
  background: linear-gradient(135deg, var(--tx), var(--tx3));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -2px;
}

.ac_hero_sub {
  font-size: var(--fz_m3);
  color: var(--tx2);
  line-height: 1.6;
  margin-bottom: 5vh;
}
.ac_hero_sub strong { color: var(--tx); }

/* ── SECTIONS ── */
.ac_sec {
  padding: 12vh 10vw;
}
.ac_sec_alt { background: var(--bg5); }

.ac_sec_head {
  text-align: center;
  margin-bottom: 8vh;
}

.ac_sec_badge {
  display: inline-flex;
  align-items: center;
  gap: 1vh;
  color: var(--tx3);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-size: var(--fz_s2);
  margin-bottom: 2vh;
}

.ac_sec_tit {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  color: var(--tx);
  letter-spacing: -1px;
}

.ac_grad {
  background: linear-gradient(135deg, #0EBEFF, #7000FF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ac_sec_sub {
  font-size: var(--fz_m2);
  color: var(--tx3);
  margin-top: 1vh;
}

/* ── CTA SECTION ── */
.ac_cta_sec { padding: 10vh 5vw; }

.ac_cta_wrap {
  position: relative;
  background: var(--bg);
  color: var(--tx);
  border: 1px solid var(--brd);
  border-radius: 4vh;
  padding: 10vh 5vw;
  text-align: center;
  overflow: hidden;
  box-shadow: 0 20px 50px rgba(0,0,0,0.05);
}

.ac_cta_glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 60%;
  height: 60%;
  background: radial-gradient(circle, rgba(14, 190, 255, 0.4) 0%, transparent 70%);
  transform: translate(-50%, -50%);
  filter: blur(50px);
  pointer-events: none;
}

.ac_cta_inner { position: relative; z-index: 2; }
.ac_cta_emoji { font-size: 5rem; display: block; margin-bottom: 2vh; }
.ac_cta_inner h2 { font-size: clamp(2rem, 5vw, 4rem); font-weight: 800; line-height: 1.1; margin-bottom: 2vh; }
.ac_cta_inner p { font-size: var(--fz_m2); opacity: 0.8; margin-bottom: 5vh; }

.ac_cta_btns {
  display: flex;
  justify-content: center;
  gap: 2vh;
  flex-wrap: wrap;
}

.ac_btn_p, .ac_btn_s {
  padding: 1.8vh 4vh;
  border-radius: 1.5vh;
  font-size: var(--fz_m1);
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 1.5vh;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  text-decoration: none;
}

.ac_btn_p { background: var(--mco); color: #fff; border: none; }
.ac_btn_p:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

.ac_btn_s { background: var(--wb); color: var(--tx); border: 1px solid var(--brd); }
.ac_btn_s:hover { background: var(--bg5); border-color: var(--tx3); }

.ac_btn_lg { padding: 2.2vh 5vh; font-size: var(--fz_m2); }

/* =========================================================================
   CSS PREMIUM
   ========================================================================= */

/* ── HERO TERMINOS ── */
.tm_hero .ac_hero_tit { font-size: clamp(2.5rem, 8vw, 5rem); }

.tm_hero_chips {
  display: flex;
  justify-content: center;
  gap: 1.5vh;
  flex-wrap: wrap;
  margin-bottom: 4vh;
}

.tm_chip {
  display: inline-flex;
  align-items: center;
  gap: 0.8vh;
  padding: 0.8vh 2vh;
  background: var(--wb);
  border: 1px solid var(--brd);
  border-radius: 5vh;
  font-size: var(--fz_s2);
  font-weight: 600;
  color: var(--tx2);
}
.tm_chip i { color: var(--mco); }

.tm_last_upd {
  font-size: var(--fz_s2);
  color: var(--tx3);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.8vh;
}
.tm_last_upd i { color: var(--mco); }

/* ── ÍNDICE RÁPIDO ── */
.tm_index_band {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5vh;
  padding: 4vh 8vw;
  background: var(--wb);
  border-top: 1px solid var(--brd);
  border-bottom: 1px solid var(--brd);
  justify-content: center;
}

.tm_index_item {
  display: inline-flex;
  align-items: center;
  gap: 0.8vh;
  padding: 0.8vh 1.8vh;
  background: var(--bg);
  border: 1px solid var(--brd);
  border-radius: 1vh;
  text-decoration: none;
  color: var(--tx2);
  font-size: var(--fz_s3);
  font-weight: 600;
  transition: all 0.2s;
}
.tm_index_item:hover {
  background: var(--bg5);
  transform: translateY(-3px);
  color: var(--tx);
  border-color: transparent;
}
.tm_index_item i { font-size: var(--fz_s4); }

/* ── SECCIONES GRID ── */
.tm_secciones { padding: 10vh 8vw; }

.tm_secs_grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
  gap: 3vh;
  margin-top: 6vh;
}

.tm_sec_card {
  background: var(--wb);
  border: 1px solid var(--brd);
  border-radius: 2vh;
  padding: 4vh;
  transition: all 0.3s ease;
  border-top: 3px solid transparent;
}
.tm_sec_card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  border-top-color: var(--mco);
}

.tm_sec_header {
  display: flex;
  align-items: flex-start;
  gap: 2.5vh;
  margin-bottom: 3vh;
}

.tm_sec_ico {
  width: 6vh;
  height: 6vh;
  border-radius: 1.5vh;
  background: color-mix(in srgb, var(--tc) 12%, transparent);
  color: var(--tc);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fz_m3);
  flex-shrink: 0;
  margin-top: 0.3vh;
}

.tm_sec_num {
  font-size: var(--fz_s1);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  display: block;
  margin-bottom: 0.3vh;
}

.tm_sec_tit {
  font-size: var(--fz_m4);
  font-weight: 800;
  color: var(--tx);
  margin: 0;
  line-height: 1.3;
}

/* ── CUERPO LEGAL ── */
.tm_sec_body p {
  font-size: var(--fz_m1);
  color: var(--tx2);
  line-height: 1.75;
  margin-bottom: 2vh;
}
.tm_sec_body p:last-child { margin-bottom: 0; }
.tm_sec_body strong { color: var(--tx); }
.tm_sec_body a { color: var(--mco); text-decoration: underline; }
.tm_sec_body a:hover { opacity: 0.8; }

.tm_list {
  list-style: none;
  margin: 0 0 2vh 0;
  display: flex;
  flex-direction: column;
  gap: 1.2vh;
}
.tm_list li {
  display: flex;
  align-items: flex-start;
  gap: 1.2vh;
  font-size: var(--fz_m1);
  color: var(--tx2);
  line-height: 1.6;
  margin: 0;
}
.tm_list li i {
  color: var(--mco);
  margin-top: 0.2vh;
  flex-shrink: 0;
  font-size: var(--fz_s4);
}

/* ── ALERTA ── */
.tm_alert {
  display: flex;
  gap: 2vh;
  align-items: flex-start;
  background: var(--bg4);
  border: 1px solid var(--bg5);
  border-radius: 1.5vh;
  padding: 2vh 2.5vh;
  margin-top: 2.5vh;
}
.tm_alert i { color: var(--mco); flex-shrink: 0; font-size: var(--fz_m2); margin-top: 0.2vh; }
.tm_alert p { margin: 0; font-size: var(--fz_s4); color: var(--tx2); line-height: 1.6; }

/* ── CONTACTO ── */
.tm_contact {
  display: flex;
  flex-direction: column;
  gap: 2vh;
  margin-top: 2vh;
}

.tm_contact_item {
  display: flex;
  align-items: center;
  gap: 2vh;
  padding: 2.5vh 3vh;
  background: var(--bg);
  border: 1px solid var(--brd);
  border-radius: 1.5vh;
  text-decoration: none;
  color: var(--tx);
  transition: all 0.25s;
}
.tm_contact_item:hover {
  background: var(--bg5);
  transform: translateX(8px);
  border-color: var(--mco);
}
.tm_contact_item i { font-size: var(--fz_m4); flex-shrink: 0; }
.tm_contact_item strong { display: block; font-size: var(--fz_m1); font-weight: 700; color: var(--tx); }
.tm_contact_item span { font-size: var(--fz_s3); color: var(--tx3); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .tm_secs_grid { grid-template-columns: 1fr; }
  .tm_secciones { padding: 8vh 5vw; }
  .tm_index_band { padding: 3vh 5vw; }
}

@media (max-width: 600px) {
  .tm_hero_chips { gap: 1vh; }
  .tm_chip { font-size: var(--fz_s3); padding: 0.7vh 1.5vh; }
  .tm_sec_card { padding: 3vh; }
}
</style>

<Layout {...seo.privacidad}>
<div class="ac_wrap tm_wrap">

  <!-- ══ HERO ══ -->
  <section class="ac_hero tm_hero">
    <div class="ac_hero_orb ac_orb1"></div>
    <div class="ac_hero_orb ac_orb2"></div>
    <div class="ac_hero_orb ac_orb3"></div>
    <div class="ac_hero_body">
      <div class="ac_hero_badge"><i class="fas fa-lock"></i> Tu privacidad es sagrada</div>
      <h1 class="ac_hero_tit">Política de<br><span class="ac_grad">Privacidad</span></h1>
      <p class="ac_hero_sub">
        En {app}, tu privacidad no es solo una obligación legal —
        es un <strong>valor fundamental</strong> que guía cada decisión que tomamos.
      </p>
      <div class="tm_hero_chips">
        <span class="tm_chip"><i class="fas fa-ban"></i> Sin venta de datos</span>
        <span class="tm_chip"><i class="fas fa-eye-slash"></i> Sin rastreo invasivo</span>
        <span class="tm_chip"><i class="fas fa-shield-halved"></i> 100% seguro</span>
      </div>
      <div class="tm_last_upd">
        <i class="fas fa-calendar-check"></i>
        Última actualización: Abril {year()}
      </div>
    </div>
  </section>

  <!-- ══ ÍNDICE RÁPIDO ══ -->
  <div class="tm_index_band">
    <a href="#tm_sec_0" class="tm_index_item">
      <i class="fas fa-database" style="color:#0EBEFF"></i>
      <span>Información que Recopilamos</span>
    </a>
    <a href="#tm_sec_1" class="tm_index_item">
      <i class="fas fa-gear" style="color:#29C72E"></i>
      <span>Cómo Usamos tu Información</span>
    </a>
    <a href="#tm_sec_2" class="tm_index_item">
      <i class="fas fa-bullhorn" style="color:#FF5C69"></i>
      <span>Publicidad y Google AdSense</span>
    </a>
    <a href="#tm_sec_3" class="tm_index_item">
      <i class="fas fa-share-nodes" style="color:#7000FF"></i>
      <span>Compartir Información con Terceros</span>
    </a>
    <a href="#tm_sec_4" class="tm_index_item">
      <i class="fas fa-cookie-bite" style="color:#FFDA34"></i>
      <span>Cookies y Almacenamiento Local</span>
    </a>
    <a href="#tm_sec_5" class="tm_index_item">
      <i class="fas fa-user-lock" style="color:#0EBEFF"></i>
      <span>Tus Derechos sobre tus Datos</span>
    </a>
    <a href="#tm_sec_6" class="tm_index_item">
      <i class="fas fa-shield-halved" style="color:#29C72E"></i>
      <span>Seguridad de tus Datos</span>
    </a>
    <a href="#tm_sec_7" class="tm_index_item">
      <i class="fas fa-child" style="color:#FF5C69"></i>
      <span>Privacidad de Menores</span>
    </a>
    <a href="#tm_sec_8" class="tm_index_item">
      <i class="fas fa-rotate" style="color:#7000FF"></i>
      <span>Cambios en esta Política</span>
    </a>
  </div>

  <!-- ══ SECCIONES ══ -->
  <section class="ac_sec tm_secciones">
    <div class="ac_sec_head">
      <div class="ac_sec_badge"><i class="fas fa-shield-halved"></i> Privacidad</div>
      <h2 class="ac_sec_tit">Tu información, <span class="ac_grad">tu control</span></h2>
      <p class="ac_sec_sub">Protegemos tus datos para que puedas enfocarte en tu crecimiento profesional.</p>
    </div>
    <div class="tm_secs_grid">
      <!-- 01 -->
      <div class="tm_sec_card wi_fadeUp" id="tm_sec_0">
        <div class="tm_sec_header">
          <div class="tm_sec_ico" style="--tc:#0EBEFF"><i class="fas fa-database"></i></div>
          <div>
            <span class="tm_sec_num" style="color:#0EBEFF">01</span>
            <h2 class="tm_sec_tit">Información que Recopilamos</h2>
          </div>
        </div>
        <div class="tm_sec_body">
          <p>{app} recopila únicamente la información necesaria para brindarte las mejores herramientas de optimización profesional y redacción:</p>
          <ul class="tm_list">
            <li><i class="fas fa-check"></i> <strong>Datos de cuenta:</strong> Nombre, correo electrónico y foto de perfil (si te registras con Google).</li>
            <li><i class="fas fa-check"></i> <strong>Contenido personal:</strong> Notas de postulación, currículums creados y configuraciones del editor.</li>
            <li><i class="fas fa-check"></i> <strong>Datos de uso:</strong> Páginas visitadas, tiempo de sesión y funciones utilizadas (de forma anónima).</li>
            <li><i class="fas fa-check"></i> <strong>Datos técnicos:</strong> Tipo de navegador, sistema operativo y dirección IP (para seguridad y diagnóstico).</li>
          </ul>
          <div class="tm_alert">
            <i class="fas fa-heart"></i>
            <p>Jamás recopilamos información financiera, contraseñas ni datos sensibles fuera de lo necesario para el inicio de sesión con Google.</p>
          </div>
        </div>
      </div>

      <!-- 02 -->
      <div class="tm_sec_card wi_fadeUp" id="tm_sec_1">
        <div class="tm_sec_header">
          <div class="tm_sec_ico" style="--tc:#29C72E"><i class="fas fa-gear"></i></div>
          <div>
            <span class="tm_sec_num" style="color:#29C72E">02</span>
            <h2 class="tm_sec_tit">Cómo Usamos tu Información</h2>
          </div>
        </div>
        <div class="tm_sec_body">
          <p>La información que recopilamos tiene un único propósito: mejorar tu experiencia de redacción y preparación en {app}.</p>
          <ul class="tm_list">
            <li><i class="fas fa-check"></i> Personalizar tu experiencia y recordar tus preferencias de tema visual y edición.</li>
            <li><i class="fas fa-check"></i> Sincronizar tus datos entre dispositivos de forma segura.</li>
            <li><i class="fas fa-check"></i> Mejorar la plataforma identificando errores y áreas de mejora.</li>
            <li><i class="fas fa-check"></i> Enviarte notificaciones importantes sobre cambios en el servicio (solo si te registraste).</li>
            <li><i class="fas fa-check"></i> Mostrar publicidad relevante a través de Google AdSense para mantener el servicio gratuito.</li>
          </ul>
        </div>
      </div>

      <!-- 03 -->
      <div class="tm_sec_card wi_fadeUp" id="tm_sec_2">
        <div class="tm_sec_header">
          <div class="tm_sec_ico" style="--tc:#FF5C69"><i class="fas fa-bullhorn"></i></div>
          <div>
            <span class="tm_sec_num" style="color:#FF5C69">03</span>
            <h2 class="tm_sec_tit">Publicidad y Google AdSense</h2>
          </div>
        </div>
        <div class="tm_sec_body">
          <p>{app} utiliza <strong>Google AdSense</strong> para mostrar anuncios publicitarios. Este servicio:</p>
          <ul class="tm_list">
            <li><i class="fas fa-check"></i> Puede usar cookies para mostrar anuncios basados en tus visitas previas a {app} y otros sitios web.</li>
            <li><i class="fas fa-check"></i> Google, como proveedor externo, utiliza cookies para servir anuncios según el historial de visitas del usuario.</li>
            <li><i class="fas fa-check"></i> Puedes optar por no recibir anuncios personalizados visitando <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ads Settings</a>.</li>
            <li><i class="fas fa-check"></i> También puedes desactivar el uso de cookies de terceros en la configuración de tu navegador.</li>
          </ul>
          <div class="tm_alert">
            <i class="fas fa-info-circle"></i>
            <p>Para más información sobre cómo Google usa los datos cuando utilizas sitios con AdSense, visita <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="noopener">policies.google.com</a>.</p>
          </div>
        </div>
      </div>

      <!-- 04 -->
      <div class="tm_sec_card wi_fadeUp" id="tm_sec_3">
        <div class="tm_sec_header">
          <div class="tm_sec_ico" style="--tc:#7000FF"><i class="fas fa-share-nodes"></i></div>
          <div>
            <span class="tm_sec_num" style="color:#7000FF">04</span>
            <h2 class="tm_sec_tit">Compartir Información con Terceros</h2>
          </div>
        </div>
        <div class="tm_sec_body">
          <p>{app} no vende, alquila ni comercializa tu información personal. Únicamente compartimos datos en estos casos:</p>
          <ul class="tm_list">
            <li><i class="fas fa-check"></i> <strong>Firebase / Google Cloud:</strong> Para autenticación, base de datos y almacenamiento en la nube.</li>
            <li><i class="fas fa-check"></i> <strong>Google AdSense:</strong> Para mostrar anuncios publicitarios relevantes.</li>
            <li><i class="fas fa-check"></i> <strong>Requerimiento legal:</strong> Si la ley lo exige o para proteger los derechos de {app} y sus usuarios.</li>
          </ul>
          <p>Todos nuestros proveedores de terceros cumplen con los más altos estándares internacionales de seguridad y privacidad.</p>
        </div>
      </div>

      <!-- 05 -->
      <div class="tm_sec_card wi_fadeUp" id="tm_sec_4">
        <div class="tm_sec_header">
          <div class="tm_sec_ico" style="--tc:#FFDA34"><i class="fas fa-cookie-bite"></i></div>
          <div>
            <span class="tm_sec_num" style="color:#FFDA34">05</span>
            <h2 class="tm_sec_tit">Cookies y Almacenamiento Local</h2>
          </div>
        </div>
        <div class="tm_sec_body">
          <p>Utilizamos cookies y LocalStorage para mejorar tu experiencia. Para más detalles, consulta nuestra <a href="/cookies" class="tm_nav">Política de Cookies</a>.</p>
          <ul class="tm_list">
            <li><i class="fas fa-check"></i> <strong>Cookies esenciales:</strong> Necesarias para que la app funcione correctamente.</li>
            <li><i class="fas fa-check"></i> <strong>LocalStorage:</strong> Guarda tus preferencias de tema y datos offline para carga instantánea.</li>
            <li><i class="fas fa-check"></i> <strong>Cookies de publicidad:</strong> Usadas por Google AdSense para anuncios relevantes.</li>
          </ul>
        </div>
      </div>

      <!-- 06 -->
