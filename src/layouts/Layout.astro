      <div class="tema" data-ths="dulce|#FF5C69"></div>
      <div class="tema mtha" data-ths="paz|#29C72E"></div>
      <div class="tema" data-ths="oro|#FFDA34"></div>
      <div class="tema" data-ths="mora|#7000FF"></div>
      <div class="tema" data-ths="futuro|#21273B"></div>
    </div>

    <!-- Script Interactivo de Selección de Temas (Optimizado al final del Body) -->
    <script>
      import { wiSmart } from '../lib/widev.js';
      wiSmart({ css: ['https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Poppins:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap'] });

      const getTheme = () => {
        try {
          const u = JSON.parse(localStorage.getItem('wiSmile') || '{}').value;
          return u?.tema || localStorage.wiTema || (window as any).wtema;
        } catch { return localStorage.wiTema || (window as any).wtema; }
      };

      const applyTheme = (ths: string) => {
        if (!ths) return;
        const [name, color] = ths.split('|');
        document.documentElement.dataset.theme = name;
        (document.querySelector('meta[name="theme-color"]') as HTMLMetaElement ||
          document.head.appendChild(Object.assign(document.createElement('meta'), { name: 'theme-color' })) as HTMLMetaElement
        ).content = color;
        localStorage.wiTema = ths;
        document.querySelectorAll<HTMLElement>('.tema').forEach(x => x.classList.toggle('mtha', x.dataset.ths === ths));
      };

      document.addEventListener('click', e => {
        const el = (e.target as HTMLElement).closest<HTMLElement>('.tema');
        if (el) applyTheme(el.dataset.ths || '');
      });

      document.addEventListener('astro:page-load', () => applyTheme(getTheme()));
    </script>
