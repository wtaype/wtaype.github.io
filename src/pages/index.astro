  display: flex;
  flex-wrap: wrap;
  gap: 2.2vh;
  justify-content: center;
  margin-top: 4vh;
}
.stack_pill {
  display: inline-flex;
  align-items: center;
  gap: 1.5vh;
  padding: 1.4vh 2.6vh;
  background: var(--wb);
  border: 1px solid var(--brd);
  border-radius: 50px;
